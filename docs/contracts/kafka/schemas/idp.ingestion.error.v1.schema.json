{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/kafka/idp.ingestion.error.v1.schema.json",
    "title": "idp.ingestion.error.v1",
    "description": "DLQ/error record для MQTT-to-Kafka ingestion.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "error_id",
        "reason_code",
        "mqtt_topic",
        "ingested_at"
    ],
    "properties": {
        "message_type": {
            "const": "idp.ingestion.error.v1"
        },
        "error_id": {
            "type": "string",
            "minLength": 1
        },
        "reason_code": {
            "type": "string",
            "enum": [
                "topic_template_mismatch",
                "payload_schema_invalid",
                "tenant_claim_invalid",
                "tenant_claim_unauthorized",
                "point_lookup_missing",
                "point_lookup_ambiguous",
                "source_config_revision_missing",
                "point_not_in_source_config"
            ]
        },
        "mqtt_topic": {
            "type": "string",
            "minLength": 1
        },
        "message_type_in": {
            "type": [
                "string",
                "null"
            ]
        },
        "asset_id": {
            "type": [
                "string",
                "null"
            ]
        },
        "agent_id": {
            "type": [
                "string",
                "null"
            ]
        },
        "source_id": {
            "type": [
                "string",
                "null"
            ]
        },
        "point_key": {
            "type": [
                "string",
                "null"
            ]
        },
        "detail": {
            "type": [
                "string",
                "null"
            ]
        },
        "raw_payload_snapshot": {
            "type": [
                "string",
                "null"
            ]
        },
        "ingested_at": {
            "type": "string",
            "format": "date-time"
        }
    }
}
