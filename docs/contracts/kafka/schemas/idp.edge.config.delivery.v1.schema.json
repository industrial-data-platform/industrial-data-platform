{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/kafka/idp.edge.config.delivery.v1.schema.json",
    "title": "idp.edge.config.delivery.v1",
    "description": "Kafka delivery envelope for MQTT retained edge agent-runtime/source configuration projection.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "tenant_id",
        "asset_id",
        "agent_id",
        "config_revision",
        "config_scope",
        "target_mqtt_topic",
        "mqtt_retain",
        "mqtt_qos",
        "operation",
        "payload_message_type",
        "payload",
        "idempotency_key",
        "issued_at"
    ],
    "properties": {
        "message_type": {
            "const": "idp.edge.config.delivery.v1"
        },
        "tenant_id": {
            "type": "string",
            "minLength": 1
        },
        "asset_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "agent_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "config_revision": {
            "type": "string",
            "minLength": 1
        },
        "config_scope": {
            "type": "string",
            "pattern": "^(agent_runtime|source:[a-z0-9][a-z0-9_-]{0,127})$"
        },
        "source_id": {
            "type": [
                "string",
                "null"
            ],
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "source_config_revision": {
            "type": [
                "string",
                "null"
            ],
            "minLength": 1
        },
        "target_mqtt_topic": {
            "type": "string",
            "description": "Retained MQTT topic to materialize: idp/v1/agents/{agent_id}/config/agent-runtime or idp/v1/agents/{agent_id}/sources/{source_id}/config.",
            "minLength": 1
        },
        "mqtt_retain": {
            "const": true
        },
        "mqtt_qos": {
            "type": "integer",
            "enum": [
                1
            ]
        },
        "operation": {
            "type": "string",
            "enum": [
                "upsert",
                "delete"
            ]
        },
        "payload_message_type": {
            "type": "string",
            "enum": [
                "idp.edge.agent-runtime-config.v1",
                "idp.edge.source-config.v1"
            ]
        },
        "payload": {
            "type": [
                "object",
                "null"
            ],
            "description": "Agent-runtime/source config payload for upsert. Null means MQTT retained delete/tombstone."
        },
        "idempotency_key": {
            "type": "string",
            "minLength": 1
        },
        "issued_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "config_scope": {
                        "const": "agent_runtime"
                    }
                },
                "required": [
                    "config_scope"
                ]
            },
            "then": {
                "properties": {
                    "source_id": {
                        "type": "null"
                    },
                    "source_config_revision": {
                        "type": "null"
                    },
                    "payload_message_type": {
                        "const": "idp.edge.agent-runtime-config.v1"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "config_scope": {
                        "pattern": "^source:"
                    }
                },
                "required": [
                    "config_scope"
                ]
            },
            "then": {
                "required": [
                    "source_id",
                    "source_config_revision"
                ],
                "properties": {
                    "source_id": {
                        "type": "string"
                    },
                    "source_config_revision": {
                        "type": "string"
                    },
                    "payload_message_type": {
                        "const": "idp.edge.source-config.v1"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "delete"
                    }
                },
                "required": [
                    "operation"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "type": "null"
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "operation": {
                        "const": "upsert"
                    }
                },
                "required": [
                    "operation"
                ]
            },
            "then": {
                "properties": {
                    "payload": {
                        "type": "object"
                    }
                }
            }
        }
    ]
}
