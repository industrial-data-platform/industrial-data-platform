{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/idp.edge.agent-runtime-config.v1.schema.json",
    "title": "idp.edge.agent-runtime-config.v1",
    "description": "Retained root agent runtime config for one Edge Telemetry Agent.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "tenant_id",
        "asset_id",
        "agent_id",
        "config_revision",
        "issued_at",
        "sources"
    ],
    "properties": {
        "message_type": {
            "const": "idp.edge.agent-runtime-config.v1"
        },
        "tenant_id": {
            "type": "string",
            "minLength": 1
        },
        "asset_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "agent_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "config_revision": {
            "type": "string",
            "minLength": 1
        },
        "issued_at": {
            "type": "string",
            "format": "date-time"
        },
        "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "source_id",
                    "source_config_revision",
                    "enabled"
                ],
                "properties": {
                    "source_id": {
                        "type": "string",
                        "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
                    },
                    "source_config_revision": {
                        "type": "string",
                        "minLength": 1
                    },
                    "enabled": {
                        "type": "boolean"
                    }
                }
            }
        }
    }
}
