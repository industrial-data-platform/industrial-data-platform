{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/edge.sqlite-outbox-record.v1.schema.json",
    "title": "edge.sqlite-outbox-record.v1",
    "description": "Запись SQLite Delivery Outbox для надежной доставки telemetry events.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "id",
        "event_id",
        "event_type",
        "payload_json",
        "status",
        "created_at",
        "available_at",
        "attempt_count"
    ],
    "properties": {
        "id": {
            "type": "integer",
            "minimum": 1
        },
        "event_id": {
            "type": "string",
            "minLength": 1,
            "description": "Непрозрачная непустая строка для дедупликации; не UUID-only."
        },
        "event_type": {
            "type": "string",
            "enum": [
                "telemetry.changed",
                "telemetry.sample"
            ]
        },
        "payload_json": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical edge.telemetry-event.v1 serialized as compact JSON."
        },
        "status": {
            "type": "string",
            "enum": [
                "pending",
                "inflight",
                "sent",
                "dead_letter"
            ]
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        },
        "available_at": {
            "type": "string",
            "format": "date-time"
        },
        "reserved_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time"
        },
        "lease_expires_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time",
            "description": "Deadline для recovery зависших inflight records после падения delivery worker."
        },
        "sent_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time"
        },
        "attempt_count": {
            "type": "integer",
            "minimum": 0
        },
        "last_error": {
            "type": [
                "string",
                "null"
            ]
        }
    }
}
