{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/edge.bootstrap-config.v1.schema.json",
    "title": "edge.bootstrap-config.v1",
    "description": "Минимальная локальная конфигурация запуска Edge Telemetry Agent. Не содержит sources/points runtime registry.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "agent_id",
        "delivery",
        "storage",
        "observability"
    ],
    "properties": {
        "agent_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]{0,127}$"
        },
        "delivery": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "transport",
                "mqtt"
            ],
            "properties": {
                "transport": {
                    "const": "mqtt"
                },
                "mqtt": {
                    "$ref": "#/$defs/mqtt_settings"
                }
            }
        },
        "storage": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "sqlite_path",
                "retention_days",
                "dead_letter_after_attempts"
            ],
            "properties": {
                "sqlite_path": {
                    "type": "string",
                    "minLength": 1
                },
                "retention_days": {
                    "type": "integer",
                    "minimum": 1
                },
                "dead_letter_after_attempts": {
                    "type": "integer",
                    "minimum": 1
                }
            }
        },
        "observability": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "log_level",
                "emit_health_events"
            ],
            "properties": {
                "log_level": {
                    "type": "string",
                    "minLength": 1
                },
                "emit_health_events": {
                    "type": "boolean"
                },
                "metrics_bind": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            }
        }
    },
    "$defs": {
        "mqtt_settings": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "enabled",
                "version",
                "broker",
                "topic_root",
                "client_id_prefix",
                "qos",
                "clean_start",
                "session_expiry_seconds",
                "telemetry_message_expiry_seconds",
                "connect_timeout_seconds",
                "retry_backoff_seconds"
            ],
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "version": {
                    "const": "5.0"
                },
                "broker": {
                    "type": "string",
                    "minLength": 1
                },
                "topic_root": {
                    "type": "string",
                    "pattern": "^[a-z0-9][a-z0-9_-]{0,127}(?:/[a-z0-9][a-z0-9_-]{0,127})*$"
                },
                "client_id_prefix": {
                    "type": "string",
                    "minLength": 1
                },
                "username_env": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "password_env": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "qos": {
                    "type": "integer",
                    "enum": [
                        1
                    ]
                },
                "clean_start": {
                    "type": "boolean"
                },
                "session_expiry_seconds": {
                    "type": "integer",
                    "minimum": 0
                },
                "telemetry_message_expiry_seconds": {
                    "type": "integer",
                    "minimum": 1
                },
                "connect_timeout_seconds": {
                    "type": "integer",
                    "minimum": 1
                },
                "retry_backoff_seconds": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "integer",
                        "minimum": 0
                    }
                }
            }
        }
    }
}
