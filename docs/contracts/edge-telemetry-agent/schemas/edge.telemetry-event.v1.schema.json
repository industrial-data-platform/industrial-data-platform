{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/edge.telemetry-event.v1.schema.json",
    "title": "edge.telemetry-event.v1",
    "description": "Каноническое telemetry event внутри Edge Telemetry Agent до MQTT wire transform.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "event_type",
        "event_id",
        "ts",
        "agent_id",
        "tenant_id",
        "asset_id",
        "source_id",
        "source_type",
        "source_config_revision",
        "point_ref",
        "name",
        "value_type",
        "value_model",
        "signal_type",
        "observation_mode",
        "value",
        "quality",
        "sequence",
        "tags"
    ],
    "properties": {
        "event_type": {
            "type": "string",
            "enum": [
                "telemetry.changed",
                "telemetry.sample"
            ]
        },
        "event_id": {
            "type": "string",
            "minLength": 1,
            "description": "Непрозрачная непустая строка для дедупликации; не UUID-only."
        },
        "ts": {
            "type": "string",
            "format": "date-time"
        },
        "agent_id": {
            "type": "string",
            "minLength": 1
        },
        "tenant_id": {
            "type": "string",
            "minLength": 1
        },
        "asset_id": {
            "type": "string",
            "minLength": 1
        },
        "source_id": {
            "type": "string",
            "minLength": 1
        },
        "source_type": {
            "type": "string",
            "minLength": 1
        },
        "source_config_revision": {
            "type": "string",
            "minLength": 1,
            "description": "Версия retained source config, использованная при формировании события."
        },
        "point_ref": {
            "type": "string",
            "minLength": 1
        },
        "name": {
            "type": "string",
            "minLength": 1
        },
        "description": {
            "type": [
                "string",
                "null"
            ]
        },
        "value_type": {
            "type": "string",
            "enum": [
                "boolean",
                "number",
                "string"
            ]
        },
        "value_model": {
            "type": "string",
            "minLength": 1
        },
        "signal_type": {
            "type": "string",
            "enum": [
                "command",
                "feedback",
                "status",
                "sensor"
            ]
        },
        "observation_mode": {
            "type": "string",
            "enum": [
                "listen",
                "read_on_start",
                "periodic_read"
            ]
        },
        "value": {
            "type": [
                "boolean",
                "number",
                "string",
                "null"
            ]
        },
        "value_raw": {
            "type": [
                "string",
                "null"
            ]
        },
        "unit": {
            "type": [
                "string",
                "null"
            ]
        },
        "quality": {
            "type": "string",
            "enum": [
                "good",
                "uncertain",
                "bad"
            ]
        },
        "sequence": {
            "type": "integer",
            "minimum": 1
        },
        "tags": {
            "type": "object",
            "additionalProperties": {
                "type": "string"
            }
        }
    }
}
