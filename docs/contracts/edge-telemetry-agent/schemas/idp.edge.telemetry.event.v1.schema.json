{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/idp.edge.telemetry.event.v1.schema.json",
    "title": "idp.edge.telemetry.event.v1",
    "description": "Thin MQTT payload для telemetry event; routing identity берется из MQTT topic path, tenant claim берется из retained agent runtime config.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "message_type",
        "tenant_id",
        "event_id",
        "event_type",
        "source_config_revision",
        "ts",
        "observation_mode",
        "value",
        "quality",
        "sequence"
    ],
    "properties": {
        "message_type": {
            "const": "idp.edge.telemetry.event.v1"
        },
        "tenant_id": {
            "type": "string",
            "minLength": 1,
            "description": "Платформенный tenant claim из retained agent runtime config; ingestion обязан валидировать его через auth/ACL и config cache."
        },
        "event_id": {
            "type": "string",
            "minLength": 1,
            "description": "Непрозрачная непустая строка для дедупликации; не UUID-only."
        },
        "event_type": {
            "type": "string",
            "enum": [
                "telemetry.changed",
                "telemetry.sample"
            ]
        },
        "source_config_revision": {
            "type": "string",
            "minLength": 1,
            "description": "Версия retained source config, использованная при формировании события."
        },
        "ts": {
            "type": "string",
            "format": "date-time"
        },
        "observation_mode": {
            "type": "string",
            "enum": [
                "listen",
                "read_on_start",
                "periodic_read"
            ]
        },
        "value": {
            "type": [
                "boolean",
                "number",
                "string",
                "null"
            ]
        },
        "value_raw": {
            "type": [
                "string",
                "null"
            ]
        },
        "quality": {
            "type": "string",
            "enum": [
                "good",
                "uncertain",
                "bad"
            ]
        },
        "sequence": {
            "type": "integer",
            "minimum": 1
        }
    }
}
