{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://industrial-data-platform.local/contracts/edge-telemetry-agent/edge.sqlite-point-state-cache.v1.schema.json",
    "title": "edge.sqlite-point-state-cache.v1",
    "description": "Persistent cache последнего состояния точки в локальном SQLite-хранилище edge-telemetry-agent.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "source_id",
        "point_ref",
        "sequence",
        "updated_at"
    ],
    "properties": {
        "source_id": {
            "type": "string",
            "minLength": 1
        },
        "point_ref": {
            "type": "string",
            "minLength": 1
        },
        "last_observed_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time"
        },
        "last_observed_value": {
            "type": [
                "boolean",
                "number",
                "string",
                "null"
            ]
        },
        "last_observed_raw": {
            "type": [
                "string",
                "null"
            ]
        },
        "last_observed_quality": {
            "type": [
                "string",
                "null"
            ],
            "enum": [
                "good",
                "uncertain",
                "bad",
                null
            ]
        },
        "last_published_at": {
            "type": [
                "string",
                "null"
            ],
            "format": "date-time"
        },
        "last_published_value": {
            "type": [
                "boolean",
                "number",
                "string",
                "null"
            ]
        },
        "last_published_raw": {
            "type": [
                "string",
                "null"
            ]
        },
        "last_published_quality": {
            "type": [
                "string",
                "null"
            ],
            "enum": [
                "good",
                "uncertain",
                "bad",
                null
            ]
        },
        "sequence": {
            "type": "integer",
            "minimum": 0
        },
        "updated_at": {
            "type": "string",
            "format": "date-time"
        }
    }
}
