          "pluginVersion": "4.15.0",
          "queryType": "table",
          "rawSql": "SELECT 'active_points' AS inferred_state, countIf(ts >= now64(3) - INTERVAL 15 MINUTE) AS points FROM telemetry_latest_v1 UNION ALL SELECT 'stale_points' AS inferred_state, countIf(ts < now64(3) - INTERVAL 15 MINUTE) AS points FROM telemetry_latest_v1 LIMIT 2",
          "refId": "A"
        }
      ],
      "title": "Point freshness",
      "type": "table"
