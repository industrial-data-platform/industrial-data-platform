          "queryType": "table",
          "rawSql": "SELECT status, count() AS agents FROM (SELECT tenant_id, asset_id, agent_id, status FROM (SELECT tenant_id, asset_id, agent_id, if(ts < now64(3) - INTERVAL 15 MINUTE, 'stale', status) AS status, 0 AS sort_priority FROM agent_status_events_v1 ORDER BY tenant_id ASC, asset_id ASC, agent_id ASC, ts DESC LIMIT 1 BY tenant_id, asset_id, agent_id UNION ALL SELECT tenant_id, asset_id, agent_id, if(ts < now64(3) - INTERVAL 15 MINUTE, 'stale', 'online') AS status, 1 AS sort_priority FROM (SELECT tenant_id, asset_id, agent_id, max(ts) AS ts FROM telemetry_latest_v1 GROUP BY tenant_id, asset_id, agent_id)) ORDER BY tenant_id ASC, asset_id ASC, agent_id ASC, sort_priority ASC LIMIT 1 BY tenant_id, asset_id, agent_id) GROUP BY status ORDER BY agents DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Agent status",
      "type": "table"
