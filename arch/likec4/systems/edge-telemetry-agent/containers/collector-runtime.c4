model {
    extend edge-telemetry-agent {
        collector-runtime = container 'ObservationProcessor' {
            description 'Основной processing use case edge_telemetry_agent: southbound-адаптеры, сбор данных, нормализация, фильтрация изменений, обновление локального state и постановка событий в delivery outbox.'
            technology 'edge_telemetry_agent.application.processing.ObservationProcessor'

            -> bootstrap-configuration 'Загружает agent_id и MQTT bootstrap-параметры'
            -> agent-runtime-config-cache 'Читает retained agent runtime/source configs, tenant_id, source_config_revision и point registry'
            -> field-protocol-gateways.knx-router 'Подключается к KNX/IP и читает group address и телеграммы'
            -> field-protocol-gateways.knx-source-emulator 'В local/dev подключается к KNX-like TCP JSON Lines endpoint и читает synthetic observations'
            -> field-protocol-gateways.modbus-gateway 'Подключается к Modbus и читает registers, coils и дискретные значения'
            -> field-protocol-gateways.opc-ua-gateway 'Подключается к OPC UA и читает nodes, subscriptions и значения'
            -> local-state-store 'Обновляет Point State Cache и сохраняет события edge.telemetry-event.v1 в Delivery Outbox'
        }
    }

}
