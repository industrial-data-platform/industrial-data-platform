model {
    extend edge-telemetry-agent {
        bootstrap-configuration = container 'BootstrapConfig' {
            description 'Минимальный локальный config object запуска edge_telemetry_agent: agent_id, MQTT endpoint, credentials/secret refs, Local State Store path и observability. Не содержит agent runtime registry sources/points.'
            technology 'edge_telemetry_agent.domain.config.BootstrapConfig / edge.bootstrap-config.v1'
        }
    }
}
