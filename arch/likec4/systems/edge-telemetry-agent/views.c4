views 'Developed Systems / edge_telemetry_agent' {
    view c2-edge-telemetry-agent-containers of edge-telemetry-agent {
        title 'C2 Containers'
        description 'Контейнерная декомпозиция `edge_telemetry_agent`. Каждый контейнер описан в отдельном файле внутри systems/edge-telemetry-agent/containers.'

        include *
        include service-engineer
        include field-protocol-gateways
        include field-protocol-gateways.*
        include industrial-data-platform
        exclude service-engineer -> industrial-data-platform
        exclude service-engineer -> industrial-data-platform.*

        style edge-telemetry-agent {
            color primary
        }

        rank source {
            service-engineer, field-protocol-gateways
        }

        rank sink {
            industrial-data-platform
        }
    }
}
