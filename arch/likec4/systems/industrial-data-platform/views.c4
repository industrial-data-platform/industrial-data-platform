views 'Developed Systems / Industrial Data Platform' {
    view c2-industrial-data-platform-containers of industrial-data-platform {
        title 'C2 Containers'
        description 'Контейнерная декомпозиция Industrial Data Platform: ingestion, config registry, Kafka-compatible event log, storage и shared platform services. Web Monitoring и Alarm Management показаны как отдельные потребляющие модули.'

        include *
        include edge-telemetry-agent
        include web-monitoring-module
        include alarm-management-module
        include service-engineer

        style industrial-data-platform {
            color primary
        }

        rank source {
            edge-telemetry-agent, service-engineer
        }
    }

    view c3-idp-config-registry-catalog of industrial-data-platform.idp-config-registry {
        title 'C3 idp_config_registry Catalog Placement'
        description 'Размещение Hierarchical Catalog V1 внутри idp_config_registry: Catalog является компонентом Config Registry / Platform Store slice, а не отдельным runtime service. Internal Backoffice UI учитывается как обязательная surface после issue #21; Web Monitoring читает catalog metadata через C2 boundary idp_config_registry.'

        include *
        include industrial-data-platform.platform-store
        include service-engineer

        style industrial-data-platform.idp-config-registry {
            color primary
        }

        rank source {
            service-engineer
        }

        rank sink {
            industrial-data-platform.platform-store
        }
    }
}
