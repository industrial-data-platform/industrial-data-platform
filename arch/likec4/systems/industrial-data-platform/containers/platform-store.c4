model {
    extend industrial-data-platform {
        platform-store = container 'Platform Store' {
            description 'Transactional PostgreSQL store ядра данных: persistence для Config Registry, Asset Graph Registry V1, shared module state, audit и persistence Keycloak.'
            technology 'PostgreSQL / transactional platform store'
            icon tech:postgresql
            style {
                shape storage
            }
        }
    }
}
